# Base de données (SQLite par défaut pour démarrer sans installer Postgres)
DATABASE_URL="file:./dev.db"
# Pour la production, remplacez par une base Postgres, ex:
# DATABASE_URL="postgresql://user:password@localhost:5432/secondie"

# Authentification
JWT_SECRET="change-moi-en-une-longue-chaine-aleatoire"
JWT_EXPIRES_IN="7d"

# Serveur
PORT=4000
CLIENT_URL="http://localhost:5173"

# Assistant IA (Anthropic) — nécessaire pour /api/ai/*
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxx"

# Vérification téléphone par SMS (optionnel) — sans ces variables, le code
# de vérification est simplement affiché dans les logs du serveur (pratique en dev).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
